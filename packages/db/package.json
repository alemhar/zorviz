{
    "name": "@zorviz/db",
    "version": "0.0.0",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "scripts": {
        "generate:sqlite": "drizzle-kit generate:sqlite --schema=./src/schema.sqlite.ts --out=./migrations/sqlite",
        "generate:pg": "drizzle-kit generate:pg --schema=./src/schema.postgres.ts --out=./migrations/pg",
        "seed": "tsx ./src/seed.ts"
    },
    "dependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/uuid": "^10.0.0",
        "@zorviz/core": "*",
        "dotenv": "^17.2.3",
        "kysely": "^0.28.10",
        "tsx": "^4.21.0",
        "uuid": "^13.0.0"
    },
    "optionalDependencies": {
        "better-sqlite3": "^12.6.2"
    },
    "devDependencies": {
        "typescript": "^5.0.0"
    }
}
